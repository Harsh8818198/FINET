import React, { useState } from 'react'
import Sidebar from './Sidebar'
import Topbar from './Topbar'
import FinetAIChat from '../components/chat/FinetAIChat'

export default function AppLayout({ children, nodes, setNodes, income, setIncome }){
  const [isChatOpen, setIsChatOpen] = useState(false)
  return (
    <div className="flex h-screen bg-[#F9F9FB] text-slate-800">
      <Sidebar />
      <div className="flex-1 flex flex-col">
        <Topbar income={income} setIncome={setIncome} />
        <main className="flex-1 overflow-y-auto p-6">{children}</main>
      </div>
      <div className="fixed bottom-6 right-6 z-50"><button onClick={()=>setIsChatOpen(s=>!s)} className="h-14 w-14 rounded-full bg-indigo-600 text-white">Chat</button></div>
      <FinetAIChat isOpen={isChatOpen} onClose={()=>setIsChatOpen(false)} income={income} nodes={nodes} />
    </div>
  )
}

